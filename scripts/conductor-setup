#!/usr/bin/env bash
# Conductor workspace setup — runs once per new workspace.
# On Debian/root, extends scripts/setup with Node.js, gh CLI, jq, and JS deps.
# On macOS/local, checks for required tools and runs scripts/setup-python.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

install_js_deps() {
  echo "[conductor-setup] Installing JS frontend deps (js/)..."
  cd "$REPO_ROOT/js"
  if [ -f package-lock.json ]; then
    npm ci --prefer-offline --ignore-scripts
  else
    npm install --ignore-scripts
  fi
  if [ -n "${SUDO_UID:-}" ] && [ -n "${SUDO_GID:-}" ]; then
    chown -R "$SUDO_UID:$SUDO_GID" node_modules/ 2>/dev/null || true
  fi
  cd "$REPO_ROOT"
}

print_summary() {
  if [ -x .venv/bin/python ]; then
    _PY_VER="$(.venv/bin/python --version 2>&1)"
  else
    _PY_VER="unknown"
  fi
  _NODE_VER="$(node --version 2>/dev/null || echo 'unknown')"
  if command -v gh >/dev/null 2>&1; then
    _GH_VER="$(gh --version | head -1)"
  else
    _GH_VER="unknown"
  fi
  echo ""
  echo "  Conductor workspace ready"
  echo "  ========================"
  echo ""
  echo "  Python:  .venv/bin/python (${_PY_VER})"
  echo "  Node:    ${_NODE_VER}"
  echo "  gh CLI:  ${_GH_VER}"
  echo ""
  echo "  Activate env:    source .env.workspace"
  echo "  Fast local loop: scripts/test-fast"
  echo "  Run HA locally:  scripts/develop"
  echo "  Build JS card:   cd js && npm run build"
  echo "  Lint:            scripts/lint  (Python)"
  echo "                   cd js && npm run lint  (TS)"
  echo "  Sync to HA box:  scripts/ha-sync --frontend-only"
  echo "  Tests:           scripts/test-python"
  echo "                   cd js && npm test  (TS/vitest)"
  echo ""
}

if command -v apt-get >/dev/null 2>&1; then
  if [ "${EUID:-$(id -u)}" -ne 0 ]; then
    echo "[conductor-setup] ERROR: must run as root (e.g. sudo scripts/conductor-setup)" >&2
    exit 1
  fi

  echo "[conductor-setup] Running Debian Python/HA bootstrap..."
  bash scripts/setup

  echo "[conductor-setup] Ensuring Node.js is available..."
  if ! command -v node >/dev/null 2>&1; then
    _NS_TMP=$(mktemp /tmp/nodesource-setup-XXXXXXXX.sh)
    curl -fsSL https://deb.nodesource.com/setup_22.x -o "$_NS_TMP"
    bash "$_NS_TMP"
    rm -f "$_NS_TMP"
    apt-get install -y --no-install-recommends nodejs
  fi
  echo "[conductor-setup] Node $(node --version), npm $(npm --version)"

  install_js_deps

  echo "[conductor-setup] Ensuring gh CLI is available..."
  if ! command -v gh >/dev/null 2>&1; then
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | tee /usr/share/keyrings/githubcli-archive-keyring.gpg > /dev/null
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list
    apt-get update -qq
    apt-get install -y --no-install-recommends gh
  fi
  echo "[conductor-setup] gh $(gh --version | head -1)"

  if ! command -v jq >/dev/null 2>&1; then
    apt-get update -qq
    apt-get install -y --no-install-recommends jq
  fi
else
  MISSING_TOOLS=()
  for tool in node npm gh jq; do
    if ! command -v "${tool}" >/dev/null 2>&1; then
      MISSING_TOOLS+=("${tool}")
    fi
  done

  if [ "${#MISSING_TOOLS[@]}" -gt 0 ]; then
    echo "[conductor-setup] ERROR: missing required tools for local setup: ${MISSING_TOOLS[*]}" >&2
    echo "  Install them, then rerun scripts/conductor-setup." >&2
    exit 1
  fi

  echo "[conductor-setup] Running local Python bootstrap..."
  bash scripts/setup-python
  echo "[conductor-setup] Node $(node --version), npm $(npm --version)"
  install_js_deps
fi

print_summary

# ── WISHLIST (not yet automated — requires auth or external install) ──────────
# The following would make the workspace fully self-sufficient but need
# manual steps or secrets that can't be embedded in a script:
#
#  gh auth login
#    → interactive browser auth; run once per workspace if GH_TOKEN is not set.
#      Workaround: set GH_TOKEN as a Conductor environment variable/secret.
#
#  gstack (global skill runner)
#    → install path depends on your gstack distribution; no public installer URL.
#      Copy from ~/ or mount via Conductor volume if available.
#
#  mempalace (cross-session memory)
#    → lives at ~/.local/bin/mempalace; same situation — mount or copy in.
#      Once available, run: mempalace init --wing lightener
#
#  Tailscale (HA SSH access)
#    → needed for `ssh root@100.98.177.107` deploys to production HA.
#      Install separately; a tailscale auth key can be injected as a secret.
